# Copy this file to `.streamlit/secrets.toml` for local development,
# OR paste the same content into Streamlit Cloud → App settings → Secrets.
#
# NEVER commit `.streamlit/secrets.toml` (it's in .gitignore).
#
# Where to find the values:
#   - SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_KEY:
#       Supabase → Project Settings → API
#       • URL                    → SUPABASE_URL
#       • anon public            → SUPABASE_ANON_KEY
#       • service_role (secret)  → SUPABASE_SERVICE_KEY   ⚠️ keep private
#   - GROQ_API_KEY:
#       https://console.groq.com/keys
#   - (Optional) GEMINI_API_KEY: fallback LLM if Groq is down.

SUPABASE_URL          = "https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY     = "eyJhbGciOi... (anon public key)"
SUPABASE_SERVICE_KEY  = "eyJhbGciOi... (service_role key — NEVER expose client-side)"

GROQ_API_KEY          = "gsk_..."
# GEMINI_API_KEY      = "..."   # optional fallback
